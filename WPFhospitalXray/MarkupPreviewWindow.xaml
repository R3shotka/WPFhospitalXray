<Window x:Class="WPFhospitalXray.MarkupPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перегляд розмітки лікаря" Height="700" Width="900" Background="#F2F6FF" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Перевірка контуру перелому (Ручна розмітка)" FontSize="18" FontWeight="Bold" Foreground="#526681" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Контейнер для зображення -->
        <Border Grid.Row="1" BorderBrush="#D0D0D0" BorderThickness="2" Background="Black">
            <Image x:Name="img_Viewer" Stretch="Uniform"/>
        </Border>

        <!-- Кнопка закриття -->
        <Button Grid.Row="2" Content="❌ Закрити перегляд" Click="btn_Close_Click" 
                Width="200" Height="40" Margin="0,15,0,0"
                Background="#95A5A6" Foreground="White" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
    </Grid>
</Window>