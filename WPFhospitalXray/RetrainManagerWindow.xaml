<Window x:Class="WPFhospitalXray.RetrainManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Керування датасетом та донавчання ШІ"
        Height="650" Width="1000"
        Background="#F2F6FF"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="7" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btn_Approve" Content="✅ Схвалити знімок" Height="35" Padding="15,0" Margin="0,0,10,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btn_Approve_Click"/>

                    <Button x:Name="btn_Reject" Content="❌ Відхилити знімок" Height="35" Padding="15,0" Margin="0,0,10,0"
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btn_Reject_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btn_ExportDataset"
            Content="📦 Сформувати датасет"
            Height="40"
            Padding="20,0"
            Background="#526681"
            Foreground="White"
            FontWeight="Bold"
            FontSize="14"
            BorderThickness="0"
            Cursor="Hand"
            Click="btn_ExportDataset_Click"
            Margin="0,0,15,0"/>

                    <Button x:Name="btn_StartRetrain"
            Content="🚀 Запустити донавчання ШІ"
            Height="40"
            Padding="20,0"
            Background="#4B7DC0"
            Foreground="White"
            FontWeight="Bold"
            FontSize="14"
            BorderThickness="0"
            Cursor="Hand"
            Click="btn_StartRetrain_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Запити на донавчання">
                <DataGrid x:Name="dg_Requests" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="White" Foreground="Black" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#D0D0D0"
                          RowBackground="White" AlternatingRowBackground="#F9FBFD" BorderBrush="#D0D0D0"
                          SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#526681"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ Запиту" Binding="{Binding Id}" Width="Auto" />
                        <DataGridTextColumn Header="Дата" Binding="{Binding RequestedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="Auto" />
                        <DataGridTextColumn Header="Лікар" Binding="{Binding DoctorName}" Width="*" />
                        <DataGridTextColumn Header="Тип випадку" Binding="{Binding RequestTypeDisplayName}" Width="*" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="Auto" />
                        <DataGridTemplateColumn Header="Дія" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="👁 Перевірити розмітку" Click="btn_PreviewMarkup_Click" Margin="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Версії моделей">
                <Grid Background="White" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F9FBFD" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Активна модель використовується для аналізу знімків. Нову або архівну версію можна активувати після перевірки."
                                       Foreground="#334155"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="btn_RefreshModels"
                                        Content="Оновити"
                                        Height="35"
                                        Padding="15,0"
                                        Margin="0,0,10,0"
                                        Background="#526681"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="btn_RefreshModels_Click"/>

                                <Button x:Name="btn_ActivateModel"
                                        Content="Активувати модель"
                                        Height="35"
                                        Padding="15,0"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="btn_ActivateModel_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="dg_ModelVersions"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="White"
                              Foreground="Black"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#D0D0D0"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBFD"
                              BorderBrush="#D0D0D0"
                              SelectionMode="Single"
                              SelectionChanged="dg_ModelVersions_SelectionChanged">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#526681"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                            <DataGridTextColumn Header="Версія" Binding="{Binding Version}" Width="1.6*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="Auto"/>
                            <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="Auto"/>
                            <DataGridTextColumn Header="Створено" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="Auto"/>
                            <DataGridTextColumn Header="Активовано" Binding="{Binding ActivatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="Auto"/>
                            <DataGridTextColumn Header="Precision" Binding="{Binding Precision, StringFormat=\{0:0.0000\}}" Width="Auto"/>
                            <DataGridTextColumn Header="Recall" Binding="{Binding Recall, StringFormat=\{0:0.0000\}}" Width="Auto"/>
                            <DataGridTextColumn Header="mAP50" Binding="{Binding Map50, StringFormat=\{0:0.0000\}}" Width="Auto"/>
                            <DataGridTextColumn Header="ONNX" Binding="{Binding OnnxPath}" Width="2.4*"/>
                            <DataGridTextColumn Header="PT" Binding="{Binding PtPath}" Width="2.4*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
