<Window x:Class="WPFhospitalXray.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFhospitalXray"
        mc:Ignorable="d"
        Title="AdminPanel" Height="600" Width="950" Background="#F2F6FF"  ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                <Button x:Name="CreatePatientBtn" Content="➕ Створити пацієнта" 
        Click="CreatePatient_btn" Margin="0,0,10,0" Padding="10,5"
        Background="#4B7DC0" Foreground="White" BorderThickness="0"/>

                <Button x:Name="EditPatientBtn" Content="✏️ Редагувати пацієнта" 
        Click="EditPatient_btn" Margin="0,0,10,0" Padding="10,5"
        IsEnabled="False" 
        Background="#6785B0" Foreground="White" BorderThickness="0"/>

                <Button x:Name="DeletePatientBtn" Content="🗑 Видалити пацієнта" 
        Click="DeletePatient_btn" Margin="0,0,0,0" Padding="10,5" 
        IsEnabled="False" 
        Background="#FFE74C3C" Foreground="White" BorderThickness="0"/>

            </StackPanel>

            <Rectangle Width="1" Fill="#D0D0D0" Margin="10,0,20,0" Height="25"/>

            <StackPanel x:Name="AdminStaffPanel" Orientation="Horizontal">
                <Button Content="👥 Створити працівника" Click="CreateStuff_btn" 
                    Margin="0,0,10,0" Padding="10,5"
                    Background="#526681" Foreground="White" BorderThickness="0"/>

                <Button Content="⚙️ Керування персоналом" Click="EditStuff_btn" 
                    Padding="10,5"
                    Background="#526681" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>

        <!-- таблиця -->

        <DataGrid x:Name="DBGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="10 40 10 10"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  SelectionChanged="DBGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата створення" Binding="{Binding CreatingDate}"/>
                <DataGridTextColumn Header="ПІБ пацієнта" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Id пацієнта" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Стать" Binding="{Binding Sex}"/>
                <DataGridTextColumn Header="Дата народження" Binding="{Binding DateOfBirth}"/>
                <DataGridTextColumn Header="Обстеження" Binding="{Binding ExaminationsCount}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
