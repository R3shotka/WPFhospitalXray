<Window x:Class="WPFhospitalXray.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFhospitalXray"
        mc:Ignorable="d"
        Title="AdminPanel" Height="600" Width="950" Background="#F2F6FF" ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="10,10,10,5" VerticalAlignment="Center">

            <StackPanel x:Name="PatientPanel" Orientation="Horizontal" Margin="0,0,20,10">
                <Button x:Name="CreatePatientBtn" Content="➕ Створити пацієнта" 
                        Click="CreatePatient_btn" Margin="0,0,10,0" Padding="10,5" Background="#4B7DC0" Foreground="White" BorderThickness="0"/>
                <Button x:Name="EditPatientBtn" Content="✏️ Редагувати пацієнта" 
                        Click="EditPatient_btn" Margin="0,0,10,0" Padding="10,5" IsEnabled="False" Background="#6785B0" Foreground="White" BorderThickness="0"/>
                <Button x:Name="DeletePatientBtn" Content="🗑 Видалити пацієнта" 
                        Click="DeletePatient_btn" Margin="0,0,0,0" Padding="10,5" IsEnabled="False" Background="#FFE74C3C" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <StackPanel x:Name="AdminStaffPanel" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="👥 Створити працівника" Click="CreateStuff_btn" 
                        Margin="0,0,10,0" Padding="10,5" Background="#526681" Foreground="White" BorderThickness="0"/>
                <Button Content="⚙️ Керування персоналом" Click="EditStuff_btn" 
                        Margin="0,0,10,0" Padding="10,5" Background="#526681" Foreground="White" BorderThickness="0"/>

                <Button Content="🧠 Керування навчанням ШІ" Click="OpenRetrainManager_Click" 
                        Padding="10,5" Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

        </WrapPanel>

        <Border Grid.Row="1" Background="#E8EEF5" BorderBrush="#D0D0D0" BorderThickness="1" Margin="10,5,10,5" Padding="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Пошук пацієнта (ПІБ або Паспорт):" FontWeight="Bold" Foreground="#526681" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox x:Name="tb_Search" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Padding="5,0" 
                         Background="White" BorderBrush="#D0D0D0" FontSize="14"
                         TextChanged="tb_Search_TextChanged"/>

                <Button x:Name="btn_Search" Grid.Column="2" Content="🔍 Пошук" 
                        Click="btn_Search_Click" Margin="10,0,0,0" Padding="15,0" Height="30"
                        Background="#4B7DC0" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="btn_ClearSearch" Grid.Column="3" Content="❌ Очистити" 
                        Click="btn_ClearSearch_Click" Margin="10,0,0,0" Padding="10,0" Height="30"
                        Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <DataGrid x:Name="DBGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="10,5,10,10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  SelectionChanged="DBGrid_SelectionChanged" MouseDoubleClick="DBGrid_MouseDoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#526681"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата створення" Binding="{Binding CreatingDate}"/>
                <DataGridTextColumn Header="ПІБ пацієнта" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Id пацієнта" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Стать" Binding="{Binding Sex}"/>
                <DataGridTextColumn Header="Дата народження" Binding="{Binding DateOfBirth}"/>
                <DataGridTextColumn Header="Обстеження" Binding="{Binding ExaminationsCount}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>