<Window x:Class="WPFhospitalXray.CreatePatient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        xmlns:local="clr-namespace:WPFhospitalXray"
        mc:Ignorable="d"
           Title="EditPatient" Height="450" Width="800" Background="#F2F6FF">
    <Grid>
        <Border Background="White"
        Width="400"
        Height="312"
        CornerRadius="7"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Margin="0 20 0 10"
                   FontFamily="Arial"
                   Text="Редагування пацієнта"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#526681"
                   HorizontalAlignment="Center"/>

                <StackPanel Orientation="Vertical" Margin="30 10 15 10">

                    <!-- Номер паспорта -->
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Номер паспорта"
                       HorizontalContentAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <TextBox x:Name="Passport_textbox"
                         Width="150"
                         Grid.Column="1"/>
                    </Grid>

                    <!-- ПІБ -->
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="ПІБ"
                       HorizontalContentAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <TextBox x:Name="FullName_textbox"
                         Width="150"
                         Grid.Column="1"/>
                    </Grid>

                    <!-- Стать -->
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Стать"
                       HorizontalContentAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <ComboBox x:Name="Sex_combobox"
                          Width="150"
                          Grid.Column="1">
                            <ComboBoxItem Content="Чоловіча"/>
                            <ComboBoxItem Content="Жіноча"/>
                        </ComboBox>
                    </Grid>

                    <!-- Дата народження -->
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Дата народження"
                       HorizontalContentAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

                        <DatePicker x:Name="BirthDate_picker"
                            Width="150"
                            Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Номер телефону"
                        HorizontalContentAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"/>

                        <TextBox x:Name="phone_textbox"
                        Width="150"
                        Grid.Column="1"/>
                    </Grid>
                    <Grid Margin="0 3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Адреса проживання"
                        HorizontalContentAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"/>

                        <TextBox x:Name="Adress_textbox"
                        Width="150"
                        Grid.Column="1"/>
                    </Grid>

                </StackPanel>
                <Grid Margin="70 10 70 0" Height="25">
                    <Button Content="Зберегти" 
            Click="SaveButton_Click" 
            Background="#4B7DC0" Foreground="White" 
            BorderThickness="0" HorizontalAlignment="Left" 
            VerticalAlignment="Top" Height="25"/>

                    <Button Content="Вийти" 
            Click="ExitButton_Click" 
            Background="#4B7DC0" Foreground="White" 
            BorderThickness="0" HorizontalAlignment="Right" 
            VerticalAlignment="Center" Height="25"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>